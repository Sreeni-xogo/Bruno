meta {
  name: Get Player
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/v2/api/Players/{{playerPIN}}/DecodePlayerPin
  body: none
  auth: none
}

headers {
  x-api-version: {{x-api-version}}
  x-manager-key: {{authToken}}
}

tests {
  test("Status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Response is a player ID", function() {
    expect(res.getBody()).to.be.a('number');
  });
}
