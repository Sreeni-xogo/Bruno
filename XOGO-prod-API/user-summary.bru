meta {
  name: User Summary
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/v2/api/users
  body: none
  auth: none
}

headers {
  x-api-version: {{x-api-version}}
  x-manager-key: {{authToken}}
}

tests {
  test("Status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Response has user data", function() {
    expect(res.getBody()).to.not.be.empty;
  });
}
