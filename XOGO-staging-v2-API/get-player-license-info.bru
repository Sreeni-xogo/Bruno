meta {
  name: Get Player License Info
  type: http
  seq: 96
}

get {
  url: {{baseUrl}}/v2/api/admin/account/licenses/players-license-info/{{billingCycle}}
  body: none
  auth: none
}

headers {
  x-api-version: {{x-api-version}}
  x-manager-key: {{authToken}}
}

tests {
  test("Status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Response is not empty", function() {
    expect(res.getBody()).to.not.be.empty;
  });
}
