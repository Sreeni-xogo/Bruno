meta {
  name: Update Player Status
  type: http
  seq: 52
}

patch {
  url: {{baseUrl}}/v2/api/Players/{{playerId}}/status
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  x-api-version: {{x-api-version}}
  x-manager-key: {{authToken}}
}

body:json {
  {
    "totalItemCountInPlaylist": 0,
    "totalDownloadedItemCount": 0,
    "playlistDownloadStatus": "Ready"
  }
}

tests {
  test("Status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
