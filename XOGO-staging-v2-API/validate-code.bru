meta {
  name: Validate Code
  type: http
  seq: 135
}

post {
  url: {{baseUrl}}/v2/api/UserEmailValidation/validateCode?email={{user2Email}}&code={{validationCode}}
  body: none
  auth: none
}

headers {
  x-api-version: {{x-api-version}}
  x-manager-key: {{authToken}}
}

tests {
  test("Status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Response is not empty", function() {
    expect(res.getBody()).to.not.be.empty;
  });
}
