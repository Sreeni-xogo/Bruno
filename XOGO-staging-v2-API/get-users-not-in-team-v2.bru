meta {
  name: Get Users Not In Team v2
  type: http
  seq: 64
}

get {
  url: {{baseUrl}}/v2/api/admin/company-teams/users-not-inteam/{{teamId}}
  body: none
  auth: none
}

headers {
  x-api-version: {{x-api-version}}
  x-manager-key: {{authToken}}
}

tests {
  test("Status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Response is not empty", function() {
    expect(Array.isArray(res.getBody())).to.be.true;
  });
}
