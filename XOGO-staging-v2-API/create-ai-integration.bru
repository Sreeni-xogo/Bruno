meta {
  name: Create AI Integration
  type: http
  seq: 120
}

post {
  url: {{baseUrl}}/v2/api/company/ai-integrations
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  x-api-version: {{x-api-version}}
  x-manager-key: {{authToken}}
}

body:json {
  {
    "provider": "OpenAI",
    "apiKey": "sk-test-crud-key-xogo"
  }
}

script:post-response {
  const data = res.getBody();
  if ((res.getStatus() === 200 || res.getStatus() === 201) && data && data.id) {
    bru.setEnvVar('crudAiIntegrationId', data.id);
  }
}

tests {
  test("Status is 201", function() {
    expect(res.getStatus()).to.equal(201);
  });

  test("Response has id", function() {
    const body = res.getBody();
    expect(body).to.have.property('id');
  });
}
