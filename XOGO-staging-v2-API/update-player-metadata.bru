meta {
  name: Update Player Metadata
  type: http
  seq: 50
}

put {
  url: {{baseUrl}}/v2/api/Players/{{playerId}}/metadata
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  x-api-version: {{x-api-version}}
  x-manager-key: {{authToken}}
}

body:json {
  {
    "screenSize": "1920x1080",
    "notes": "test-metadata"
  }
}

tests {
  test("Status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
