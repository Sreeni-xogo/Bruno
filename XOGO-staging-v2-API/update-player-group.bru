meta {
  name: Update Player Group
  type: http
  seq: 56
}

put {
  url: {{baseUrl}}/v2/api/PlayerGroups
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  x-api-version: {{x-api-version}}
  x-manager-key: {{authToken}}
}

body:json {
  {
    "id": {{crudPlayerGroupId}},
    "name": "crud-player-group-updated",
    "overridePlayerPlaylists": false
  }
}

tests {
  test("Status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
